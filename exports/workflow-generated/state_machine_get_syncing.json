{
  "Comment": "GitPulse State Machine generated for Trigger: GET syncing",
  "StartAt": "GET_syncing",
  "States": {
    "GET_syncing": {
      "Type": "Pass",
      "Comment": "Trigger: GET syncing (HTTP_ROUTE)",
      "Next": "handleSync"
    },
    "handleSync": {
      "Type": "Task",
      "Resource": "arn:aws:lambda:us-east-1:123456789012:function:handleSync",
      "Retry": [
        {
          "ErrorEquals": [
            "States.ALL"
          ],
          "IntervalSeconds": 3,
          "MaxAttempts": 3,
          "BackoffRate": 2
        }
      ],
      "Next": "fetchData"
    },
    "fetchData": {
      "Type": "Task",
      "Resource": "arn:aws:lambda:us-east-1:123456789012:function:fetchData",
      "Retry": [
        {
          "ErrorEquals": [
            "States.ALL"
          ],
          "IntervalSeconds": 3,
          "MaxAttempts": 3,
          "BackoffRate": 2
        }
      ],
      "Next": "log"
    },
    "fetchBranches": {
      "Type": "Task",
      "Resource": "arn:aws:lambda:us-east-1:123456789012:function:fetchBranches",
      "Retry": [
        {
          "ErrorEquals": [
            "States.ALL"
          ],
          "IntervalSeconds": 3,
          "MaxAttempts": 3,
          "BackoffRate": 2
        }
      ],
      "Next": "setBranch"
    },
    "fetch___": {
      "Type": "Task",
      "Resource": "arn:aws:states:::dynamodb:putItem",
      "Retry": [
        {
          "ErrorEquals": [
            "States.ALL"
          ],
          "IntervalSeconds": 3,
          "MaxAttempts": 3,
          "BackoffRate": 2
        }
      ],
      "End": true
    },
    "log": {
      "Type": "Task",
      "Resource": "arn:aws:lambda:us-east-1:123456789012:function:log",
      "Retry": [
        {
          "ErrorEquals": [
            "States.ALL"
          ],
          "IntervalSeconds": 3,
          "MaxAttempts": 3,
          "BackoffRate": 2
        }
      ],
      "Next": "log"
    },
    "setBranch": {
      "Type": "Task",
      "Resource": "arn:aws:lambda:us-east-1:123456789012:function:setBranch",
      "Retry": [
        {
          "ErrorEquals": [
            "States.ALL"
          ],
          "IntervalSeconds": 3,
          "MaxAttempts": 3,
          "BackoffRate": 2
        }
      ],
      "Next": "updateUrl"
    },
    "updateUrl": {
      "Type": "Task",
      "Resource": "arn:aws:lambda:us-east-1:123456789012:function:updateUrl",
      "Retry": [
        {
          "ErrorEquals": [
            "States.ALL"
          ],
          "IntervalSeconds": 3,
          "MaxAttempts": 3,
          "BackoffRate": 2
        }
      ],
      "Next": "fetch___"
    }
  }
}